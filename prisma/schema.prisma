generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  email          String   @unique
  displayName    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}