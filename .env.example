DATABASE_URL="postgresql://postgres:postgres@localhost:5432/patitasupdb?schema=public"

# Optional override for Prisma CLI migrations.
# Use the direct Supabase connection here when you want `prisma migrate *` to target Supabase.
PRISMA_MIGRATE_DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# Required only if you run `prisma migrate dev` against a cloud database.
# It must NOT be the same URL as PRISMA_MIGRATE_DATABASE_URL.
SHADOW_DATABASE_URL="postgresql://postgres:your-shadow-password@db.your-shadow-project-ref.supabase.co:5432/postgres?sslmode=require"

# If your password includes reserved URL characters like <, >, @, :, /, or ?, percent-encode them.

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional fallback for older Supabase projects still using the anon key name.
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
